# GEMINI_API_KEY: Optional. Used only when Gemini is selected as the LLM provider.
# Prefer configuring provider credentials through the local Workbench settings.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Optional externally visible URL for self-referential links or callbacks.
# Local releases normally use the Workbench Server URL.
APP_URL="http://127.0.0.1:19780"
