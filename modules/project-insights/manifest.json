{
  "$schema": "../schema/module-manifest.schema.json",
  "schemaVersion": "mepbridge-module-manifest-1",
  "id": "project-insights",
  "version": "0.1.0",
  "apiVersion": "1",
  "displayName": {
    "zh-CN": "项目概览",
    "en-US": "Project Insights"
  },
  "description": {
    "zh-CN": "组合读取当前 Archicad 项目信息和楼层列表，不修改模型。",
    "en-US": "Combines current Archicad project metadata and story information without modifying the model."
  },
  "riskLevel": "read-only",
  "entry": "server/index.js",
  "descriptors": "descriptors.json",
  "permissions": {
    "archicad": {
      "access": "read",
      "commands": [
        "MEPBridge.GetProjectInfo",
        "MEPBridge.GetStories"
      ]
    },
    "filesystem": "none",
    "network": "none"
  }
}
